      ],
      "see_instead": [
        {
          "when": "the metric value itself is the story",
          "use": "CH-TIM-01"
        },
        {
          "when": "only two periods",
          "use": "CH-TIM-05"
        }
      ],
      "implemented_by": [
        "svg",
        "pptx"
      ]
    }
  },
  "use_when": [
